"""
LineFollowPID.py

PID-based line-following controller for the MainController firmware.

This module reads position error from an IR sensor array and computes
motor speed corrections using a PID control loop. It integrates with:

    - MotorDriver   : low-level motor speed / direction interface
    - IRArraySensor : reads the line position from an array of IR sensors

Expected collaborator interfaces (adjust import paths to match your
project layout):

    class IRArraySensor:
        def read_line_position(self) -> float:
            \"\"\"
            Returns a normalized line position error in the range
            [-1.0, 1.0], where:
                0.0  = line centered under the sensor array
               -1.0  = line fully to the left
               +1.0  = line fully to the right
            \"\"\"

    class MotorDriver:
        def set_speeds(self, left_speed: float, right_speed: float) -> None:
            \"\"\"
            Sets left/right motor speeds. Values are expected in the
            range [-max_speed, max_speed], where negative values
            reverse the motor.
            \"\"\"
"""

import time

# Adjust these relative imports to match your actual package structure.
try:
    from ..Motor.MotorDriver import MotorDriver
except ImportError:
    MotorDriver = None  # Allows this module to be imported/tested standalone

try:
    from ..Sensors.IRArraySensor import IRArraySensor
except ImportError:
    IRArraySensor = None  # Allows this module to be imported/tested standalone


class LineFollowPID:
    """
    PID controller that reads line position error from an IRArraySensor
    and drives a MotorDriver to keep the robot centered on the line.
    """

    def __init__(
        self,
        motor_driver,
        ir_sensor,
        kp: float = 0.8,
        ki: float = 0.0,
        kd: float = 0.15,
        base_speed: float = 60.0,
        max_speed: float = 100.0,
        integral_limit: float = 50.0,
    ):
        """
        :param motor_driver:    MotorDriver instance controlling the drivetrain.
        :param ir_sensor:       IRArraySensor instance providing line error readings.
        :param kp:              Proportional gain.
        :param ki:              Integral gain.
        :param kd:              Derivative gain.
        :param base_speed:      Nominal forward speed (both motors) when centered on the line.
        :param max_speed:       Absolute maximum speed magnitude sent to either motor.
        :param integral_limit:  Clamp applied to the accumulated integral term (anti-windup).
        """
        self.motor_driver = motor_driver
        self.ir_sensor = ir_sensor

        self.kp = kp
        self.ki = ki
        self.kd = kd

        self.base_speed = base_speed
        self.max_speed = max_speed
        self.integral_limit = integral_limit

        self._last_error = 0.0
        self._integral = 0.0
        self._last_time = None
        self._last_output = 0.0  # used by smooth_turn() for output slew limiting

        # Max allowed change in PID output per update, used to prevent
        # jerky/abrupt turns. Tune alongside Kp/Kd.
        self.max_output_delta = 40.0

    # ------------------------------------------------------------------
    # Error acquisition
    # ------------------------------------------------------------------
    def update_error(self) -> float:
        """
        Reads the current line position error from the IR sensor array.

        :return: normalized error in [-1.0, 1.0], 0.0 = centered on the line.
        """
        error = self.ir_sensor.read_line_position()

        # Defensive clamp in case the sensor driver returns an
        # out-of-range or noisy value.
        error = max(-1.0, min(1.0, error))
        return error

    # ------------------------------------------------------------------
    # Core PID computation
    # ------------------------------------------------------------------
    def calculate_pid(self, error: float) -> float:
        """
        Computes the PID correction term for a given error, using
        wall-clock time to derive dt for the integral and derivative terms.

        :param error: normalized line position error in [-1.0, 1.0].
        :return: raw PID output (unbounded correction signal).
        """
        now = time.monotonic()

        if self._last_time is None:
            dt = 0.0
        else:
            dt = now - self._last_time
        self._last_time = now

        # Avoid divide-by-zero / huge derivative spikes on the first call
        # or if dt is unexpectedly tiny.
        if dt <= 0.0:
            dt = 1e-3

        # --- Proportional term ---
        p_term = self.kp * error

        # --- Integral term (with anti-windup clamp) ---
        self._integral += error * dt
        self._integral = max(-self.integral_limit, min(self.integral_limit, self._integral))
        i_term = self.ki * self._integral

        # --- Derivative term ---
        derivative = (error - self._last_error) / dt
        d_term = self.kd * derivative
        self._last_error = error

        output = p_term + i_term + d_term
        return output

    # ------------------------------------------------------------------
    # Output shaping
    # ------------------------------------------------------------------
    def smooth_turn(self, pid_output: float) -> float:
        """
        Slew-rate limits the PID output so motor commands change gradually
        rather than jumping abruptly, which reduces jitter and wheel slip
        on sharp corrections.

        :param pid_output: raw output from calculate_pid().
        :return: smoothed output value.
        """
        delta = pid_output - self._last_output

        if delta > self.max_output_delta:
            pid_output = self._last_output + self.max_output_delta
        elif delta < -self.max_output_delta:
            pid_output = self._last_output - self.max_output_delta

        self._last_output = pid_output
        return pid_output

    # ------------------------------------------------------------------
    # Motor actuation
    # ------------------------------------------------------------------
    def adjust_motor_speed(self, pid_output: float) -> None:
        """
        Converts a (smoothed) PID output into differential left/right
        motor speeds and sends them to the MotorDriver.

        Positive pid_output steers right (slow the right wheel, speed up
        the left wheel); negative steers left.

        :param pid_output: smoothed correction value from smooth_turn().
        """
        left_speed = self.base_speed - pid_output
        right_speed = self.base_speed + pid_output

        # Clamp to the motor driver's valid speed range.
        left_speed = max(-self.max_speed, min(self.max_speed, left_speed))
        right_speed = max(-self.max_speed, min(self.max_speed, right_speed))

        self.motor_driver.set_speeds(left_speed, right_speed)

    # ------------------------------------------------------------------
    # Main control loop step
    # ------------------------------------------------------------------
    def update(self) -> None:
        """
        Executes a single control loop iteration:
            1. Read error from the IR array
            2. Compute PID correction
            3. Smooth the output
            4. Apply it to the motors

        Call this repeatedly (e.g. in a fixed-rate loop) to follow the line.
        """
        error = self.update_error()
        pid_output = self.calculate_pid(error)
        smoothed_output = self.smooth_turn(pid_output)
        self.adjust_motor_speed(smoothed_output)

    def reset(self) -> None:
        """Resets internal PID state (integral, last error, timing, output)."""
        self._last_error = 0.0
        self._integral = 0.0
        self._last_time = None
        self._last_output = 0.0


# ----------------------------------------------------------------------
# Example standalone usage (remove or adapt when integrating into the
# main firmware loop).
# ----------------------------------------------------------------------
if __name__ == "__main__":
    if MotorDriver is None or IRArraySensor is None:
        raise SystemExit(
            "MotorDriver / IRArraySensor not found — update the import "
            "paths at the top of this file to match your project layout."
        )

    motor_driver = MotorDriver()
    ir_sensor = IRArraySensor()

    controller = LineFollowPID(
        motor_driver=motor_driver,
        ir_sensor=ir_sensor,
        kp=0.8,
        ki=0.0,
        kd=0.15,
        base_speed=60.0,
        max_speed=100.0,
    )

    try:
        while True:
            controller.update()
            time.sleep(0.02)  # ~50 Hz control loop
    except KeyboardInterrupt:
        motor_driver.set_speeds(0, 0)
